# Authelia root domain.
AUTHELIA_DOMAIN=m3w.ch

# Authelia FQDN.
AUTHELIA_FQDN=authelia.${AUTHELIA_DOMAIN}

# Authelia default redirection URL.
AUTHELIA_DEFAULT_REDIRECTION_URL=https://${AUTHELIA_DOMAIN}

# Authelia JWT secret.
AUTHELIA_JWT_SECRET=CHANGE_ME

# Authelia session secret.
AUTHELIA_SESSION_SECRET=CHANGE_ME

# Authelia storage encryption key.
AUTHELIA_STORAGE_ENCRYPTION_KEY=CHANGE_ME

# The PUID to use
PUID=1000

# The PGID to use
PGID=1000

# The umask to use
UMASK=022
