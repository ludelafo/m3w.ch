# The timezone to use
TZ=UTC

# The server name (default `Docker Samba Server`)
SAMBA_SERVER_STRING=NAS

# The log level
SAMBA_LOG_LEVEL=0

# Enable service discovery for Linux and macOS (default `0`)
AVAHI_ENABLE=1

# Interface to listen on
AVAHI_INTERFACES=eth0

# Enable service discovery for Windows (default `0`)
WSDD2_ENABLE=1

# Interface to listen on
WSDD2_INTERFACE=eth0

# Override hostname (default to host or container name)
WSDD2_HOSTNAME=CHANGE_ME

# Set NetBIOS name (default to host or container name)
WSDD2_NETBIOS_NAME=CHANGE_ME
