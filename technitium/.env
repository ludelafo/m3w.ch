## Fully qualified domain names (FQDNs)
# The FQDN to access Technitium
TECHNITIUM_FQDN=technitium.m3w.ch

## Versions to use
# The version to use for Technitium
TECHNITIUM_VERSION=14.3.0

## Container and Traefik names
# The name to use for Technitium
TECHNITIUM_CONTAINER_NAME=technitium

## Network configuration
# The network interface to use for the MACVLAN network
MACVLAN_NETWORK_INTERFACE=wlan0

# The IP address range for the MACVLAN network
MACVLAN_NETWORK_SUBNET=192.168.1.0/24

# The gateway for the MACVLAN network
MACVLAN_NETWORK_GATEWAY=192.168.1.1

# The IP address for the container
MACVLAN_NETWORK_IP=192.168.1.254
