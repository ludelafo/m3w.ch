## Fully qualified domain names (FQDNs)
# The FQDN to access Beszel
BESZEL_FQDN=beszel.m3w.ch

## Versions to use
# The version to use for Beszel (Hub)
BESZEL_IMAGE_VERSION=0

# The version to use for Beszel Agent
BESZEL_AGENT_IMAGE_VERSION=alpine

## Container and Traefik names
# The name to use for Beszel (Hub)
BESZEL_CONTAINER_NAME=beszel

# The name to use for Beszel (Agent)
BESZEL_AGENT_CONTAINER_NAME=beszel-agent
