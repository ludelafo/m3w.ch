# Create first user with this email.
BESZEL_HUB_USER_EMAIL=admin+beszel@m3w.ch

# Create first user with this password.
BESZEL_HUB_USER_PASSWORD=CHANGE_ME

# Enables automatic user creation for OAuth2 / OIDC.
USER_CREATION=true

# Disables password authentication.
DISABLE_PASSWORD_AUTH=true

# Allows access to all systems by all users.
SHARE_ALL_SYSTEMS=true
