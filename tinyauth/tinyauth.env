# Comma-separated list of users (username:hashed_password).
# https://tinyauth.app/docs/getting-started/#user-creation
# test:test
TINYAUTH_AUTH_USERS=test:$$2a$$10$$UMzpQ7zjHFoA3sknOA8BBu4bzwXJlxV67mfSqDG.WHFzOkM7.IxPy

# Bind DN for LDAP authentication.
TINYAUTH_LDAP_BINDDN=uid=tinyauth,ou=people,dc=m3w,dc=ch

# Bind password for LDAP authentication.
TINYAUTH_LDAP_BINDPASSWORD=CHANGE_ME

# Base DN for LDAP searches.
TINYAUTH_LDAP_BASEDN=dc=m3w,dc=ch
