## Fully qualified domain names (FQDNs)
# The FQDN to access Tinyauth
TINYAUTH_FQDN=tinyauth.m3w.ch

# The FQDN to access LLDAP
TINYAUTH_FQDN=LLDAP.m3w.ch

## Versions to use
# The version to use for Tinyauth
TINYAUTH_IMAGE_VERSION=v5

# The version to use for LLDAP
LLDAP_IMAGE_VERSION=stable

## Container and Traefik names
# The name to use for Tinyauth
TINYAUTH_CONTAINER_NAME=tinyauth

# The name to use for LLDAP
LLDAP_CONTAINER_NAME=lldap
