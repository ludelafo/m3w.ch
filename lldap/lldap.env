# Distinguished Name. Change if needed.
LLDAP_LDAP_BASE_DN=dc=m3w,dc=ch

# If using SMTP, set the following variables
# Enable password reset.
LLDAP_SMTP_OPTIONS__ENABLE_PASSWORD_RESET=true

# SMTP host.
LLDAP_SMTP_OPTIONS__SERVER=smtp.example.com

# SMTP port.
LLDAP_SMTP_OPTIONS__PORT=465

# How the connection is encrypted, either "NONE" (no encryption, port 25), "TLS" (sometimes called SSL, port 465) or "STARTTLS" (sometimes called TLS, port 587).
LLDAP_SMTP_OPTIONS__SMTP_ENCRYPTION=TLS

# SMTP user.
LLDAP_SMTP_OPTIONS__USER=no-reply@example.com

# SMTP password.
LLDAP_SMTP_OPTIONS__PASSWORD=PasswordGoesHere 

# The header field, optional: how the sender appears in the email. The first is a free-form name, followed by an email between <>.
LLDAP_SMTP_OPTIONS__FROM=no-reply <no-reply@example.com>

# Same for reply-to, optional.
LLDAP_SMTP_OPTIONS__TO=admin <admin@example.com> 
