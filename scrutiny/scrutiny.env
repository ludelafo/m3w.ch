# Master API token for collector and programmatic access.
SCRUTINY_WEB_AUTH_TOKEN=CHANGE_ME

# The secret to sign JWTs.
SCRUTINY_WEB_AUTH_JWT_SECRET=CHANGE_ME

# API token to use for the collector
COLLECTOR_API_TOKEN=${SCRUTINY_WEB_AUTH_TOKEN}

# API token to use for the performance collector
COLLECTOR_PERF_API_TOKEN=${SCRUTINY_WEB_AUTH_TOKEN}

# When to run the collector (cron schedule format)
COLLECTOR_CRON_SCHEDULE="*/5 * * * *"

# If the collector runs on startup (true/false)
COLLECTOR_RUN_STARTUP=true

# When to run the performance collector (cron schedule format)
COLLECTOR_PERF_CRON_SCHEDULE="*/1 * * * *"

# If the performance collector runs on startup (true/false)
COLLECTOR_PERF_RUN_STARTUP=true
