## Fully qualified domain names (FQDNs)
# The FQDN to access Traefik
TRAEFIK_FQDN=traefik.m3w.ch

## Versions to use
# The version to use for Traefik
TRAEFIK_IMAGE_VERSION=v3

## Container and Traefik names
# The name to use for Traefik
TRAEFIK_CONTAINER_NAME=traefik

# The secret to use for OIDC authentication in Traefik
TRAEFIK_OIDC_SECRET=MLFs4TT99kOOq8h3UAVRtYoCTDYXiRcZ

# The client ID to use for OIDC authentication in Traefik
TRAEFIK_OIDC_CLIENT_ID=CHANGE_ME

# The client secret to use for OIDC authentication in Traefik
TRAEFIK_OIDC_CLIENT_SECRET=CHANGE_ME
